generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// Better Auth core tables
// =========================================================
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  // app relations
  driverProfile DriverProfile?
  vehicles      Vehicle[]
  workShifts    WorkShift[]
  expenses      Expense[]
  fuelLogs      FuelLog[]
  reminders     Reminder[]
  goals         Goal[]
  importJobs    ImportJob[]
  attachments   Attachment[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// =========================================================
// Perfil del conductor
// =========================================================
model DriverProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  preferredCurrency String   @default("ARS") @map("preferred_currency")
  timezone          String   @default("America/Argentina/Buenos_Aires")
  defaultVehicleId  String?  @map("default_vehicle_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_profiles")
}

// =========================================================
// Dominio
// =========================================================

enum Platform {
  UBER
  CABIFY
  DIDI
  MAXIM
  INDRIVE
  OTHER
}

enum IncomeType {
  PLATFORM
  TIP
  BONUS
  OTHER
}

enum ExpenseCategory {
  FUEL
  TOLLS
  WASH
  INSURANCE
  REGISTRATION
  SERVICE
  OIL_CHANGE
  TIRES
  PARTS
  FINES
  OTHER
}

enum FuelType {
  NAFTA
  DIESEL
  GNC
  ELECTRIC
  HYBRID
}

enum ReminderType {
  DATE
  ODOMETER
}

enum ReminderEntity {
  OIL_CHANGE
  FILTER
  INSURANCE
  VTV
  REGISTRATION
  TIRES
  SERVICE
  OTHER
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Vehicle {
  id           String    @id @default(uuid())
  userId       String
  brand        String
  model        String
  year         Int?
  licensePlate String    @map("license_plate")
  currentKm    Decimal   @map("current_km") @db.Decimal(10, 2)
  fuelType     FuelType  @map("fuel_type")
  tankCapacity Decimal?  @map("tank_capacity") @db.Decimal(10, 2)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workShifts WorkShift[]
  expenses   Expense[]
  fuelLogs   FuelLog[]
  reminders  Reminder[]

  @@index([userId])
  @@index([deletedAt])
  @@map("vehicles")
}

model WorkShift {
  id          String    @id @default(uuid())
  userId      String
  vehicleId   String?
  date        DateTime  @db.Date
  startedAt   DateTime  @map("started_at")
  endedAt     DateTime? @map("ended_at")
  onlineHours Decimal?  @map("online_hours") @db.Decimal(5, 2)
  totalTrips  Int       @default(0) @map("total_trips")
  distanceKm  Decimal?  @map("distance_km") @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle  Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  incomes  ShiftIncome[]
  expenses Expense[]

  @@index([userId, date])
  @@index([vehicleId])
  @@index([deletedAt])
  @@map("work_shifts")
}

model ShiftIncome {
  id        String     @id @default(uuid())
  shiftId   String     @map("shift_id")
  type      IncomeType
  platform  Platform?
  amount    Decimal    @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  shift WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@map("shift_incomes")
}

model Expense {
  id          String          @id @default(uuid())
  userId      String
  vehicleId   String?
  shiftId     String?
  category    ExpenseCategory
  date        DateTime        @db.Date
  description String
  amount      Decimal         @db.Decimal(12, 2)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle     Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  shift       WorkShift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  fuelLog     FuelLog?
  attachments Attachment[]

  @@index([userId, date])
  @@index([category])
  @@index([vehicleId])
  @@index([shiftId])
  @@index([deletedAt])
  @@map("expenses")
}

model FuelLog {
  id                   String    @id @default(uuid())
  userId               String
  vehicleId            String
  expenseId            String?   @unique @map("expense_id")
  date                 DateTime  @db.Date
  station              String?
  notes                String?
  liters               Decimal   @db.Decimal(10, 3)
  pricePerLiter        Decimal   @map("price_per_liter") @db.Decimal(12, 4)
  totalAmount          Decimal   @map("total_amount") @db.Decimal(12, 2)
  odometerKm           Decimal   @map("odometer_km") @db.Decimal(10, 2)
  fullTank             Boolean   @default(true) @map("full_tank")
  consumptionLPer100Km Decimal?  @map("consumption_l_per_100km") @db.Decimal(10, 2)
  efficiencyKmPerL     Decimal?  @map("efficiency_km_per_l") @db.Decimal(10, 2)
  costPerKm            Decimal?  @map("cost_per_km") @db.Decimal(12, 4)
  estimatedRangeKm     Decimal?  @map("estimated_range_km") @db.Decimal(10, 2)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([userId, vehicleId, date])
  @@index([deletedAt])
  @@map("fuel_logs")
}

model Reminder {
  id          String         @id @default(uuid())
  userId      String
  vehicleId   String
  type        ReminderType
  entity      ReminderEntity
  title       String
  dueDate     DateTime?      @map("due_date") @db.Date
  dueOdometer Decimal?       @map("due_odometer") @db.Decimal(10, 2)
  isCompleted Boolean        @default(false) @map("is_completed")
  completedAt DateTime?      @map("completed_at")
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, vehicleId])
  @@index([dueDate])
  @@map("reminders")
}

model Goal {
  id           String     @id @default(uuid())
  userId       String
  period       GoalPeriod
  targetAmount Decimal    @map("target_amount") @db.Decimal(12, 2)
  startDate    DateTime   @map("start_date") @db.Date
  endDate      DateTime?  @map("end_date") @db.Date
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, startDate])
  @@index([userId, period])
  @@map("goals")
}

model ImportJob {
  id            String       @id @default(uuid())
  userId        String
  source        String // ej: 'uber_csv'
  fileUrl       String?      @map("file_url")
  status        ImportStatus @default(PENDING)
  rawData       Json?        @map("raw_data")
  processedRows Int          @default(0) @map("processed_rows")
  errorLog      Json?        @map("error_log")
  startedAt     DateTime?    @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("import_jobs")
}

model Attachment {
  id        String   @id @default(uuid())
  userId    String
  expenseId String?  @map("expense_id")
  key       String
  url       String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expenseId])
  @@map("attachments")
}
